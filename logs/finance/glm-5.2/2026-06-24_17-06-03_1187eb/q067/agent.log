    tool_output=ToolOutput(
        output='[{"url": "https://spaceodysseyhub.com/articles/launch-cost-comparison-2025", "title": "Launch Cost Comparison 2026: Falcon 9 vs Vulcan vs New Glenn vs Neutron | SpaceOdysseyHub", "content": "Payload to LEO: ~27,200 kg (heaviest configuration with 6 SRBs)\\n Payload to GTO: ~14,400 kg\\n Payload to TLI: ~12,100 kg\\n Published price: ~$110 million list (varies widely by configuration and customer mix)\\n Estimated cost per kg to LEO: ~$5,000\\u20138,000 (depending on configuration)\\n Reliability: Operational; multiple national security and Kuiper missions completed since 2024\\n Reusability: Expendable booster; planned SMART engine recovery has been deprioritized", "score": 0.85097736, "raw_content": null}, {"url": "https://spacem12.com/vulcan-centaur", "title": "Vulcan Centaur: Revolutionary Space Launch - Spacem12", "content": "How much does a Vulcan Centaur launch cost? Launch prices vary based on payload requirements and configuration. ULA offers customized quotes but estimates suggest costs range from $110 million to $200 million depending on mission complexity.\\n\\nWhen will engine recovery begin? ULA plans to test the SMART reusability system within the next few years. The exact timeline depends on completing development and flight testing of the recovery hardware.", "score": 0.8319231, "raw_content": null}, {"url": "https://www.myspaceteacher.com/Rockets/rocketnew/15", "title": "My Space Teacher: Vulcan Centaur", "content": "# Vulcan Centaur. Vulcan Centaur is a two-stage-to-orbit, heavy-lift launch vehicle that is under development by the United Launch Alliance (ULA) since 2014 with an initial flight expected in 2021. #### Quick Facts About Vulcan Centaur. - Payload to LEO : (Vulcan centaur Heavy) 27,200 kg (60,000 lb). - Payload to GTO : (Vulcan centaur Heavy) 7,200 kg (15,900 lb). - Payload to TLI : (Vulcan centaur Heavy)12,100 kg (26,700 lb). Initially scheduled for an inaugural flight in 2020, the program was", "score": 0.78709817, "raw_content": null}, {"url": "https://www.ulalaunch.com/docs/default-source/evolution/vulcan-centaur-overview-17may2018.pdf", "title": "ULA vulcan centaur system briefing", "content": "From Both Coasts Supports Full Range of Orbits 12 VULCAN CENTAUR PERFORMANCE Vehicle Orbit  Vulcan Centaur (2-solid) Vulcan Centaur (6-solid) Vulcan Centaur Heavy (2023) LEO ER 28.7\\u00b0 (Ref.) 200 km circular 17800 kg [39200 lb] 27400 kg [60300 lb] 34900 kg [76900 lb] LEO ER 51.6\\u00b0 (ISS) 407 km circular 15300 kg [33800 lb] 24200 kg [53400 lb] 31400 kg [69300 lb] LEO WR 90\\u00b0 (Polar) 200 km circular 14300 kg [31500 lb] 22300 kg [49200 lb] 27900 kg [61500 lb] GTO 1800 m/s 35,786 km x 185 km @ 27.0 deg", "score": 0.43323857, "raw_content": null}, {"url": "https://www.facebook.com/groups/spacehipsters/posts/26129884619963074", "title": "Space Hipsters | Does anyone have an idea/guestimate on what the actual payload costs of launch systems are as expressed in dollars per kilogram | Facebook", "content": "- Based on publicly available data from 20 launches with published payload mass numbers over the past three years, dedicated customer LEO launches have averaged just 3,370 kg of payload, just 19% of total capacity. (Note, the figure does not include rideshare, non-LEO, or classified/undisclosed payload mass missions.). - Falcon 9\\u2019s price per kg based on a max 17.5-ton capacity basis is low at ~$4,000 per kg. - Looking at Falcon 9\\u2019s price per kg based on the average mass deployed by customers on", "score": 0.36391866, "raw_content": null}, {"url": "https://www.ulalaunch.com/docs/default-source/evolution/vulcan-centaur_faa-commercial-space-transportation_final.pdf", "title": "Vulcan Centaur Launch System", "content": "Vulcan Centaur is the Future of Affordable, Flexible, and Reliable Space Flight", "score": 0.33809948, "raw_content": null}, {"url": "http://www.ulalaunch.com/docs/default-source/evolution/vulcan-centaur_faa-commercial-space-transportation_final.pdf?sfvrsn=a1d6710_2", "title": "VULCAN CENTAUR LAUNCH SYSTEM", "content": "(Aft End Centaur) Multi-Launch I/F Single Payload Configuration 24 U LVI PLA Rideshare ESPA ESPA ESPA LVI PLA LVI PLA ESPA SV1 PLA LVI Aft PLA SV2 LVI Fwd PLA SV1 LVI Fwd PLA SV1 LVI Aft PLA ESPA ESPA ESPA SV1 LVI PLA SUMMARY Vulcan Centaur Provides the World\\u2019s Best Value for Launch Services \\u2022 Innovation Hardware Solutions Provide Affordable Space Access \\u2022 Reliable Launch of Critical Customer Payloads Leverages Atlas and Delta Experience and Mission Success \\u2022 Retains Flight Proven Systems for", "score": 0.33463344, "raw_content": null}, {"url": "https://sky-brokers.com/wp-content/uploads/2025/06/ULA-Vulcan-Centaur-Launch-Vehicle.pdf", "title": "VUlcan centaUr", "content": "Vulcan Centaur includes options for two payload fairing configurations\\u2014our traditional 5.4-meter payload fairing or a new 4.4-meter payload fairing option. The 4-meter vehicle configuration will accommodate up to four Orbital ATK solid rocket boosters while the 5-meter vehicle configuration accommodates up to six. The solid rocket boosters will provide more operational capability and launch vehicle performance than ever\\u2013eventually leading to a single core Vulcan ACES vehicle. STRATEGIC", "score": 0.31830552, "raw_content": null}, {"url": "https://theaviationist.com/2025/08/07/ula-vulcan-first-military-launch", "title": "ULA Vulcan Centaur Rocket to Launch First Military Payload on August 12th - The Aviationist", "content": "An upgrade is in development which would see the engine module separate from the stack after use and return safely to the ground using an inflatable heat shield, allowing the BE-4 engines to be recovered, refurbished, and re-used. This would bring down individual launch costs, which the company will hope will help to attract commercial customers currently enticed by the Falcon 9\\u2019s remarkably cost-effective offering.", "score": 0.29862478, "raw_content": null}, {"url": "https://rocketlaunch.org/launch-schedule/ula/vulcan-centaur", "title": "Vulcan Centaur Launch Schedule", "content": "Last Update: NET Q1 2026.\\n\\nNROL-64\\n\\nImage 16: ULA logo\\nULA\\n\\nTBD\\n\\n2026\\n\\n\\ud83d\\udccd Cape Canaveral Space Force Station\\n\\n\\ud83d\\ude80 Vulcan\\n\\n\\ud83c\\udfaf Unknown\\n\\nClassified payload for the US National Reconnaissance Office\\n\\nLast Update: NET Q2, after USSF-57.\\n\\nNROL-83\\n\\nImage 17: ULA logo\\nULA\\n\\nTBD\\n\\n2026\\n\\n\\ud83d\\udccd Vandenberg SFB\\n\\n\\ud83d\\ude80 Vulcan\\n\\n\\ud83c\\udfaf Unknown\\n\\nClassified payload for the US National Reconnaissance Office\\n\\nUpdated: Sep 3, 6:00pm UTC\\n\\nSDA Tranche 1 Tracking Layer B\\n\\nImage 18: ULA logo\\nULA\\n\\nTBD\\n\\n2026\\n\\n\\ud83d\\udccd Vandenberg SFB\\n\\n\\ud83d\\ude80 Vulcan", "score": 0.2602606, "raw_content": null}]',
