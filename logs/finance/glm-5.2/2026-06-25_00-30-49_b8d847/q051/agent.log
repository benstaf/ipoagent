        parsed_args={
            'prompt': 'What risk factors does {{spacex_s1}} disclose about the orbital AI compute infrastructure, lunar economy, Mars colonization, and other long-term initiatives? What specific warnings does the filing provide about the uncertainty of these markets?'
        }
